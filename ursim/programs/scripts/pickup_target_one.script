on_target_position = [0, -1.918888889, -2.79253, 0, 1.5708, 0]

# Move the robot to the definde position, with acceleration as 'a' and velocity parameter as 0.5
# movej equals move joints
movej(on_target_position, a = 1.5, v = 0.5)
current_pose = get_actual_tcp_pose()
new_pose = pose_add(current_pose, p[0, 0, 0.2, 0, 0, 0])
movel(new_pose)   
